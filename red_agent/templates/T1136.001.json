{
  "technique_id": "T1136.001",
  "technique_name": "Create Account: Local Account",
  "tactic": "Persistence",
  "events": [
    {
      "note": "net.exe used to create the account — Sysmon catches the LOLBin execution",
      "sourcetype": "XmlWinEventLog:Microsoft-Windows-Sysmon/Operational",
      "template": {
        "EventCode": 1,
        "EventDescription": "Process Create",
        "Image": "C:\\Windows\\System32\\net.exe",
        "CommandLine": "net user {new_account} P@ssw0rd123! /add",
        "ParentImage": "C:\\Windows\\System32\\cmd.exe",
        "User": "CORP\\{creating_user}",
        "IntegrityLevel": "High"
      },
      "count": 1,
      "spread_seconds": 1
    },
    {
      "note": "Security audit: account created",
      "sourcetype": "WinEventLog:Security",
      "template": {
        "EventCode": 4720,
        "TargetUserName": "{new_account}",
        "TargetDomainName": "{workstation}",
        "SubjectUserName": "{creating_user}",
        "SubjectDomainName": "CORP",
        "SamAccountName": "{new_account}",
        "UserPrincipalName": ""
      },
      "count": 1,
      "spread_seconds": 1
    },
    {
      "note": "Account immediately enabled (new accounts may be disabled by default)",
      "sourcetype": "WinEventLog:Security",
      "template": {
        "EventCode": 4722,
        "TargetUserName": "{new_account}",
        "TargetDomainName": "{workstation}",
        "SubjectUserName": "{creating_user}",
        "SubjectDomainName": "CORP"
      },
      "count": 1,
      "spread_seconds": 1
    },
    {
      "note": "Account added to Administrators — escalation to local admin",
      "sourcetype": "WinEventLog:Security",
      "template": {
        "EventCode": 4732,
        "MemberName": "{new_account}",
        "GroupName": "Administrators",
        "GroupDomainName": "Builtin",
        "SubjectUserName": "{creating_user}",
        "SubjectDomainName": "CORP"
      },
      "count": 1,
      "spread_seconds": 2
    }
  ],
  "mutation_hints": {
    "evadable_fields": ["TargetUserName", "SubjectUserName", "GroupName"],
    "objective": "Create a hidden backdoor local admin account for persistent access"
  }
}
