{
  "technique_id": "T1021.001",
  "technique_name": "Remote Services: Remote Desktop Protocol",
  "tactic": "Lateral Movement",
  "events": [
    {
      "sourcetype": "WinEventLog:Security",
      "template": {
        "EventCode": 4624,
        "EventDescription": "An account was successfully logged on",
        "Account_Name": "{target_user}",
        "Source_Network_Address": "{attacker_ip}",
        "Logon_Type": 10,
        "Authentication_Package": "Negotiate",
        "Workstation_Name": "{workstation}"
      },
      "count": 1,
      "spread_seconds": 1
    },
    {
      "sourcetype": "WinEventLog:Security",
      "template": {
        "EventCode": 4648,
        "EventDescription": "A logon was attempted using explicit credentials",
        "Account_Name": "{target_user}",
        "Target_Server_Name": "{target_host}",
        "Process_Name": "C:\\Windows\\System32\\mstsc.exe"
      },
      "count": 1,
      "spread_seconds": 1
    }
  ],
  "mutation_hints": {
    "evadable_fields": ["Source_Network_Address", "Workstation_Name"],
    "objective": "Establish RDP session to target_host as target_user"
  }
}
