        "Account_Name": "{target_user}",
        "Source_Network_Address": "{attacker_ip}",
        "Logon_Type": 3,
        "Workstation_Name": "{workstation}"
      },
      "count": 1,
      "spread_seconds": 5,
      "note": "Successful login after brute force"
    }
  ],
  "mutation_hints": {
    "evadable_fields": ["count", "spread_seconds", "Source_Network_Address", "Logon_Type"],
