      "sourcetype": "XmlWinEventLog:Microsoft-Windows-Sysmon/Operational",
      "template": {
        "EventCode": 1,
        "EventDescription": "Process Create",
        "Image": "C:\\Windows\\System32\\rundll32.exe",
        "CommandLine": "rundll32.exe C:\\Windows\\System32\\comsvcs.dll,MiniDump 640 C:\\Windows\\Temp\\svchost.dmp full",
        "ParentImage": "C:\\Windows\\System32\\cmd.exe",
        "User": "CORP\\{target_user}",
        "IntegrityLevel": "High",
        "Hashes": "SHA256=EF3179D498793BF4234F708D3BE28633FD08099E5C1B9B4AF5B9F30F1E0F93A0"
      },
      "count": 1,
      "spread_seconds": 1
    },
    {
      "note": "Sysmon 10: ProcessAccess on lsass — GrantedAccess mask determines dumper capability",
      "sourcetype": "XmlWinEventLog:Microsoft-Windows-Sysmon/Operational",
      "template": {
        "EventCode": 10,
        "EventDescription": "Process accessed",
        "SourceImage": "C:\\Windows\\System32\\rundll32.exe",
