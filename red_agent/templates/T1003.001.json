    {
      "note": "Dump file created on disk — Sysmon 11 FileCreate catches the output",
      "sourcetype": "XmlWinEventLog:Microsoft-Windows-Sysmon/Operational",
      "template": {
        "EventCode": 11,
        "EventDescription": "File created",
        "Image": "C:\\Windows\\System32\\rundll32.exe",
        "TargetFilename": "C:\\Windows\\Temp\\svchost.dmp",
